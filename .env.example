# Server Configuration
PORT=8080
ENV=development

# Database Configuration
DATABASE_URL=postgres://postgres:postgres123@localhost:5432/food_delivery?sslmode=disable

# JWT Configuration
# Generate a strong secret with: openssl rand -hex 32
# The app refuses to boot in non-development envs if this is empty or the
# "change-me-in-production" placeholder.
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32
JWT_EXPIRATION=24h

# CORS Configuration (comma-separated allowed origins; "*" allows any)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Email / SMTP (for password-reset links and future notifications).
# Leave SMTP_HOST empty in development to use the dev "logging mailer" (emails
# are logged, not sent). Outside development SMTP_HOST and MAIL_FROM are required.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@example.com
# Public base URL used to build links in emails (e.g. the reset link). Point it
# at the web app (SPA) origin — the /reset-password screen lives there.
APP_BASE_URL=http://localhost:5173

# Payments (iyzico). Leave IYZICO_API_KEY empty in development to use the dev
# mock gateway (no real charges; a sandbox payment page is simulated by the
# SPA). Outside development real credentials are required.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Migration
AUTO_MIGRATE=true

# Redis (optional). Backs the token denylist + auth rate limiter so they are
# shared across API instances. Empty = in-memory (fine for one instance).
REDIS_URL=

# Uploaded photos (dish/kitchen). A Docker volume in compose setups.
UPLOAD_DIR=uploads

# Platform time zone: chefs' working hours are written and evaluated in it.
TIMEZONE=Europe/Istanbul

# Money model (#65). All optional; zeros = free delivery, no commission.
# Delivery fee (charged to the customer, per chef slice): base + per-km when
# both sides have coordinates. Commission: % of the food subtotal, deducted
# from the chef's earnings (customer never pays it).
DELIVERY_BASE_FEE=0
DELIVERY_FEE_PER_KM=0
COMMISSION_PERCENT=0
