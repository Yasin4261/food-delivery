# Server Configuration
PORT=8080
ENV=development

# Database Configuration
DATABASE_URL=postgres://postgres:postgres123@localhost:5432/food_delivery?sslmode=disable

# JWT Configuration
# Generate a strong secret with: openssl rand -hex 32
# The app refuses to boot in non-development envs if this is empty or the
# "change-me-in-production" placeholder.
JWT_SECRET=replace-with-output-of-openssl-rand-hex-32
JWT_EXPIRATION=24h

# CORS Configuration (comma-separated allowed origins; "*" allows any)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Email / SMTP (for password-reset links and future notifications).
# Leave SMTP_HOST empty in development to use the dev "logging mailer" (emails
# are logged, not sent). Outside development SMTP_HOST and MAIL_FROM are required.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@example.com
# Public base URL used to build links in emails (e.g. the reset link).
APP_BASE_URL=http://localhost:8080

# Migration
AUTO_MIGRATE=true
