# Production environment template.
#   cp .env.prod.example .env.prod   # then fill EVERY required value
# .env.prod is gitignored — never commit real secrets.
# Compose (${VAR:?}) and the API's ENV=production fail-fast both refuse to
# start with missing/weak values.

# --- Public origin (Caddy) ---
# ":80" serves plain HTTP (local prod test / behind a load balancer that does
# TLS). Set your domain (e.g. "food.example.com") for automatic HTTPS via
# Let's Encrypt — DNS must already point at this server.
SITE_ADDRESS=:80
# The public URL users see; used for email links and payment callbacks.
# With a domain + auto-HTTPS: https://food.example.com
APP_BASE_URL=

# --- Database ---
DB_NAME=food_delivery
DB_USER=postgres
DB_PASSWORD=

# --- Auth ---
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION=24h

# --- Email (required in production) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=

# --- Payments: iyzico (required in production) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# Switch to https://api.iyzipay.com when leaving the sandbox.
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# --- Redis (optional; required when running MORE THAN ONE api instance) ---
# e.g. redis://redis:6379/0 — backs token revocation + rate limiting.
REDIS_URL=

# Backups (optional; defaults shown). Nightly pg_dump + uploads snapshot into
# ./backups on the host. Copy that directory off-site!
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=14

# --- Money model (#65; optional, zeros = free) ---
DELIVERY_BASE_FEE=10
DELIVERY_FEE_PER_KM=2
COMMISSION_PERCENT=10

# --- Observability (#73; only needed with `--profile monitoring`) ---
GRAFANA_ADMIN_PASSWORD=change-me

ETA_MINUTES=45
