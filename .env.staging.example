# Staging environment (#75). Copy to .env.staging and fill the required values.
# Staging mirrors production's topology but ENV=staging permits the mock
# payment gateway + dev logging mailer, so SMTP and iyzico are optional.

# --- required ---
DB_PASSWORD=change-me-staging-db-password
JWT_SECRET=change-me-openssl-rand-hex-32   # real secret required (not the placeholder)

# --- public origin ---
# For a plain-HTTP staging on custom ports (default 8090):
SITE_ADDRESS=:80
APP_BASE_URL=http://localhost:8090
# For a real staging subdomain with auto-HTTPS, set instead:
#   SITE_ADDRESS=staging.example.com
#   APP_BASE_URL=https://staging.example.com
#   HTTP_PORT=80
#   HTTPS_PORT=443

# --- host ports (defaults let staging coexist with a prod stack) ---
HTTP_PORT=8090
HTTPS_PORT=8453

# --- image tag (staging tracks main) ---
TAG=main

# --- optional: real integrations (absent = mocks) ---
# SMTP_HOST=
# MAIL_FROM=
# IYZICO_API_KEY=       # iyzico sandbox keys to exercise real checkout (#51)
# IYZICO_SECRET_KEY=

# --- money model (staging defaults to non-zero to exercise the flow) ---
DELIVERY_BASE_FEE=10
DELIVERY_FEE_PER_KM=2
COMMISSION_PERCENT=10
